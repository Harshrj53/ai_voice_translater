# ─── Large Media Files (don't commit, download/generate at runtime) ───────────
*.mp4
*.avi
*.mov
*.mkv
*.wav
*.mp3
*.flac
test_video.mp4      # source test video (re-downloaded via gdown)
output_*.mp4        # generated output videos

# Allow small sample outputs to be committed if needed
!output_sample*.mp4

# ─── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ─── IDE / OS ─────────────────────────────────────────────────────────────────
